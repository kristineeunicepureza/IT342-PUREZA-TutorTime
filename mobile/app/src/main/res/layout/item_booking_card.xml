<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/item_booking_card.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_card"
    android:padding="18dp"
    android:layout_marginBottom="12dp">

    <!-- Avatar -->
    <FrameLayout
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="14dp">
        <View android:layout_width="48dp" android:layout_height="48dp"
            android:background="@drawable/bg_avatar" />
        <TextView android:id="@+id/tvBookingInitial"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_gravity="center" android:text="M"
            android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold" />
    </FrameLayout>

    <!-- Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView android:id="@+id/tvBookingName"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Mark Reyes" android:textColor="#111827"
            android:textSize="15sp" android:textStyle="bold" />

        <TextView android:id="@+id/tvBookingSubject"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Mathematics" android:textColor="#0047AB"
            android:textSize="13sp" android:textStyle="bold"
            android:layout_marginTop="2dp" />

        <!-- Meta chips row -->
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="6dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📅 Mon, 3:00 PM" android:textColor="#6B7280"
                android:textSize="12sp" android:layout_marginEnd="14dp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⏱ 1.5 hrs" android:textColor="#6B7280"
                android:textSize="12sp" android:layout_marginEnd="14dp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📍 Room 201" android:textColor="#6B7280"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Right: badge + cancel button -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end">

        <TextView android:id="@+id/tvBookingBadge"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Confirmed"
            android:textColor="#0047AB"
            android:textSize="11sp" android:textStyle="bold"
            android:background="@drawable/bg_badge_confirmed"
            android:paddingStart="10dp" android:paddingEnd="10dp"
            android:paddingTop="3dp" android:paddingBottom="3dp"
            android:layout_marginBottom="8dp" />

        <TextView android:id="@+id/btnCancelBooking"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Cancel"
            android:textColor="#DC2626"
            android:textSize="12sp" android:textStyle="bold"
            android:background="@drawable/bg_btn_cancel"
            android:paddingStart="12dp" android:paddingEnd="12dp"
            android:paddingTop="5dp" android:paddingBottom="5dp"
            android:clickable="true" android:focusable="true" />

    </LinearLayout>

</LinearLayout>