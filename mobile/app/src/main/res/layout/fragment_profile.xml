<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/fragment_profile.xml -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ── PROFILE HERO CARD ─────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_card"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <!-- Large avatar -->
            <FrameLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_marginEnd="18dp">
                <View android:layout_width="72dp" android:layout_height="72dp"
                    android:background="@drawable/bg_avatar_large" />
                <TextView android:id="@+id/tvProfileInitial"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_gravity="center" android:text="K"
                    android:textColor="#FFFFFF" android:textSize="28sp" android:textStyle="bold" />
            </FrameLayout>

            <!-- Name + email + badges -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">

                <TextView android:id="@+id/tvProfileName"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Kristine Dela Cruz"
                    android:textColor="#111827" android:textSize="20sp" android:textStyle="bold"
                    android:letterSpacing="-0.02" />

                <TextView android:id="@+id/tvProfileEmail"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="kristine@tutortime.ph"
                    android:textColor="#6B7280" android:textSize="13sp"
                    android:layout_marginTop="3dp" />

                <!-- Badge row -->
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="8dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Student"
                        android:textColor="#0047AB" android:textSize="11sp" android:textStyle="bold"
                        android:background="@drawable/bg_badge_confirmed"
                        android:paddingStart="10dp" android:paddingEnd="10dp"
                        android:paddingTop="4dp" android:paddingBottom="4dp"
                        android:layout_marginEnd="6dp" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="✓ Verified"
                        android:textColor="#10B981" android:textSize="11sp" android:textStyle="bold"
                        android:background="@drawable/bg_badge_completed"
                        android:paddingStart="10dp" android:paddingEnd="10dp"
                        android:paddingTop="4dp" android:paddingBottom="4dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ── ACCOUNT DETAILS CARD ───────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:layout_marginBottom="16dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Account Details"
                android:textColor="#111827" android:textSize="15sp" android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <!-- Full Name row -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingTop="11dp" android:paddingBottom="11dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Full Name"
                    android:textColor="#6B7280" android:textSize="13sp" />
                <TextView android:id="@+id/tvDetailName"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Kristine Dela Cruz"
                    android:textColor="#111827" android:textSize="13sp" android:textStyle="bold" />
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E8EF" />

            <!-- Email row -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingTop="11dp" android:paddingBottom="11dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Email"
                    android:textColor="#6B7280" android:textSize="13sp" />
                <TextView android:id="@+id/tvDetailEmail"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="kristine@tutortime.ph"
                    android:textColor="#111827" android:textSize="13sp" android:textStyle="bold" />
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E8EF" />

            <!-- Role row -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingTop="11dp" android:paddingBottom="11dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Role"
                    android:textColor="#6B7280" android:textSize="13sp" />
                <TextView android:id="@+id/tvDetailRole"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Student"
                    android:textColor="#111827" android:textSize="13sp" android:textStyle="bold" />
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E8EF" />

            <!-- University row -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingTop="11dp" android:paddingBottom="11dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="University"
                    android:textColor="#6B7280" android:textSize="13sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="University of Cebu"
                    android:textColor="#111827" android:textSize="13sp" android:textStyle="bold" />
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E8EF" />

            <!-- Member since row -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingTop="11dp" android:paddingBottom="4dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Member Since"
                    android:textColor="#6B7280" android:textSize="13sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="March 2026"
                    android:textColor="#111827" android:textSize="13sp" android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

        <!-- ── ACTIONS CARD ───────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:layout_marginBottom="16dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Settings"
                android:textColor="#111827" android:textSize="15sp" android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <!-- Edit profile -->
            <LinearLayout android:id="@+id/rowEditProfile"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:clickable="true" android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="✏️" android:textSize="16sp" android:layout_marginEnd="14dp" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Edit Profile"
                    android:textColor="#111827" android:textSize="14sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textColor="#6B7280" android:textSize="20sp" />
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E8EF" />

            <!-- Change password -->
            <LinearLayout android:id="@+id/rowChangePassword"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:clickable="true" android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🔒" android:textSize="16sp" android:layout_marginEnd="14dp" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Change Password"
                    android:textColor="#111827" android:textSize="14sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textColor="#6B7280" android:textSize="20sp" />
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E8EF" />

            <!-- Notifications -->
            <LinearLayout android:id="@+id/rowNotifications"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:clickable="true" android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🔔" android:textSize="16sp" android:layout_marginEnd="14dp" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Notifications"
                    android:textColor="#111827" android:textSize="14sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textColor="#6B7280" android:textSize="20sp" />
            </LinearLayout>

        </LinearLayout>

        <!-- ── LOGOUT BUTTON ─────────────────── -->
        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Log Out"
            android:textColor="#DC2626"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/bg_btn_cancel"
            android:stateListAnimator="@null"
            android:layout_marginBottom="8dp" />

    </LinearLayout>
</ScrollView>