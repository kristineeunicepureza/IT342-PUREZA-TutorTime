<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:minHeight="100dp">

        <!-- Logo Circle -->
        <FrameLayout
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp">

            <View
                android:id="@+id/logoCircle"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/bg_logo_circle" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="T"
                android:textColor="#FFFFFF"
                android:textSize="36sp"
                android:textStyle="bold" />
        </FrameLayout>

        <!-- App Name -->
        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="28dp"
            android:text="TutorTime"
            android:textColor="#0047AB"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="-0.02" />

        <!-- Welcome Text -->
        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="6dp"
            android:text="Welcome Back"
            android:textColor="#111827"
            android:textSize="24sp"
            android:textStyle="bold"
            android:letterSpacing="-0.02" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="28dp"
            android:text="Sign in to continue to your account"
            android:textColor="#6B7280"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.5"
            android:gravity="center" />

        <!-- Error Message -->
        <LinearLayout
            android:id="@+id/layoutError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_error_box"
            android:padding="10dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#DC2626"
                android:textSize="13sp"
                android:text="" />
        </LinearLayout>

        <!-- Email Input -->
        <LinearLayout
            android:id="@+id/fieldEmail"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_input_field"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✉"
                android:textSize="16sp"
                android:textColor="#6B7280"
                android:layout_marginEnd="10dp" />

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:hint="Email address"
                android:textColorHint="#AAAAAA"
                android:textColor="#222222"
                android:textSize="14sp"
                android:inputType="textEmailAddress"
                android:imeOptions="actionNext"
                android:singleLine="true" />
        </LinearLayout>

        <!-- Password Input -->
        <LinearLayout
            android:id="@+id/fieldPassword"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_input_field"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔒"
                android:textSize="16sp"
                android:textColor="#6B7280"
                android:layout_marginEnd="10dp" />

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:hint="Password"
                android:textColorHint="#AAAAAA"
                android:textColor="#222222"
                android:textSize="14sp"
                android:inputType="textPassword"
                android:imeOptions="actionDone"
                android:singleLine="true" />

            <ImageView
                android:id="@+id/ivTogglePassword"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_eye_off"
                android:contentDescription="Toggle password visibility"
                android:padding="2dp" />
        </LinearLayout>

        <!-- Forgot Password -->
        <TextView
            android:id="@+id/tvForgotPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Forgot Password?"
            android:textColor="#0047AB"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="end"
            android:layout_marginBottom="24dp"
            android:clickable="true"
            android:focusable="true" />

        <!-- Sign In Button -->
        <Button
            android:id="@+id/btnSignIn"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Sign In"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/bg_btn_primary"
            android:stateListAnimator="@null"
            android:layout_marginBottom="24dp"
            android:letterSpacing="0.01" />

        <!-- Sign Up Link -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Don't have an account? "
                android:textColor="#555555"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvSignUp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign Up"
                android:textColor="#0047AB"
                android:textSize="14sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>