<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ── PAGE HEADER ──────────────────── -->
        <!-- tvGreeting -->
        <TextView
            android:id="@+id/tvGreeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            xmlns:tools="http://schemas.android.com/tools"
            tools:text="Good morning, Kristine 👋"
            android:textColor="#111827"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="-0.02"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/dashboard_subtitle"
            android:textColor="#6B7280"
            android:textSize="13sp"
            android:layout_marginBottom="20dp" />

        <!-- ── STATS ROW (2x2 grid) ─────────── -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="2"
            android:useDefaultMargins="false"
            android:layout_marginBottom="20dp">

            <!-- Sessions -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginEnd="8dp"
                android:layout_marginBottom="8dp">
                <FrameLayout android:layout_width="44dp" android:layout_height="44dp"
                    android:background="@drawable/bg_stat_blue" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_gravity="center" android:text="📚" android:textSize="20sp" />
                </FrameLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="12" android:textColor="#111827" android:textSize="26sp"
                    android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Sessions" android:textColor="#6B7280" android:textSize="12sp"
                    android:layout_marginTop="4dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="↑ 2 this week" android:textColor="#10B981" android:textSize="11sp"
                    android:textStyle="bold" android:layout_marginTop="5dp" />
            </LinearLayout>

            <!-- Tutors -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="8dp">
                <FrameLayout android:layout_width="44dp" android:layout_height="44dp"
                    android:background="@drawable/bg_stat_green" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_gravity="center" android:text="👩‍🏫" android:textSize="20sp" />
                </FrameLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="4" android:textColor="#111827" android:textSize="26sp"
                    android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Tutors" android:textColor="#6B7280" android:textSize="12sp"
                    android:layout_marginTop="4dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="↑ 1 new" android:textColor="#10B981" android:textSize="11sp"
                    android:textStyle="bold" android:layout_marginTop="5dp" />
            </LinearLayout>

            <!-- Hours -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginEnd="8dp">
                <FrameLayout android:layout_width="44dp" android:layout_height="44dp"
                    android:background="@drawable/bg_stat_amber" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_gravity="center" android:text="⏱" android:textSize="20sp" />
                </FrameLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="28h" android:textColor="#111827" android:textSize="26sp"
                    android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Hours Learned" android:textColor="#6B7280" android:textSize="12sp"
                    android:layout_marginTop="4dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="↑ 6h this week" android:textColor="#10B981" android:textSize="11sp"
                    android:textStyle="bold" android:layout_marginTop="5dp" />
            </LinearLayout>

            <!-- Rating -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginStart="8dp">
                <FrameLayout android:layout_width="44dp" android:layout_height="44dp"
                    android:background="@drawable/bg_stat_purple" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_gravity="center" android:text="⭐" android:textSize="20sp" />
                </FrameLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="4.9" android:textColor="#111827" android:textSize="26sp"
                    android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Avg. Rating" android:textColor="#6B7280" android:textSize="12sp"
                    android:layout_marginTop="4dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="↑ 0.1 up" android:textColor="#10B981" android:textSize="11sp"
                    android:textStyle="bold" android:layout_marginTop="5dp" />
            </LinearLayout>

        </GridLayout>

        <!-- ── UPCOMING SESSIONS CARD ────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Upcoming Sessions"
                    android:textColor="#111827"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <!-- tvSeeAllBookings -->
                <TextView
                    android:id="@+id/tvSeeAllBookings"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="See all"
                    android:textColor="#0047AB"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Booking row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">
                <FrameLayout android:layout_width="40dp" android:layout_height="40dp"
                    android:layout_marginEnd="12dp">
                    <View android:layout_width="40dp" android:layout_height="40dp"
                        android:background="@drawable/bg_avatar" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_gravity="center" android:text="M"
                        android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" />
                </FrameLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Mark Reyes" android:textColor="#111827"
                        android:textSize="14sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Mathematics • Today, 3:00 PM" android:textColor="#6B7280"
                        android:textSize="12sp" android:layout_marginTop="2dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📍 Room 201, SB Building" android:textColor="#9CA3AF"
                        android:textSize="11sp" android:layout_marginTop="2dp" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Confirmed" android:textColor="#0047AB" android:textSize="11sp"
                    android:textStyle="bold" android:background="@drawable/bg_badge_confirmed"
                    android:paddingStart="10dp" android:paddingEnd="10dp"
                    android:paddingTop="3dp" android:paddingBottom="3dp" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#E5E8EF" />

            <!-- Booking row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="12dp"
                android:paddingBottom="4dp">
                <FrameLayout android:layout_width="40dp" android:layout_height="40dp"
                    android:layout_marginEnd="12dp">
                    <View android:layout_width="40dp" android:layout_height="40dp"
                        android:background="@drawable/bg_avatar_sm_green" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_gravity="center" android:text="A"
                        android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" />
                </FrameLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Ana Santos" android:textColor="#111827"
                        android:textSize="14sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Physics • Tue, 1:00 PM" android:textColor="#6B7280"
                        android:textSize="12sp" android:layout_marginTop="2dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📍 Room 105" android:textColor="#9CA3AF"
                        android:textSize="11sp" android:layout_marginTop="2dp" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Pending" android:textColor="#F59E0B" android:textSize="11sp"
                    android:textStyle="bold" android:background="@drawable/bg_badge_pending"
                    android:paddingStart="10dp" android:paddingEnd="10dp"
                    android:paddingTop="3dp" android:paddingBottom="3dp" />
            </LinearLayout>

        </LinearLayout>

        <!-- ── FEATURED TUTORS CARD ──────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Featured Tutors"
                    android:textColor="#111827"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <!-- tvSeeAllTutors -->
                <TextView
                    android:id="@+id/tvSeeAllTutors"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="See all"
                    android:textColor="#0047AB"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Tutor mini grid -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:useDefaultMargins="false">

                <!-- Tutor card 1 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_tutor_mini_card"
                    android:padding="12dp"
                    android:layout_marginEnd="6dp"
                    android:clickable="true"
                    android:focusable="true">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <FrameLayout android:layout_width="34dp" android:layout_height="34dp"
                            android:layout_marginEnd="8dp">
                            <View android:layout_width="34dp" android:layout_height="34dp"
                                android:background="@drawable/bg_avatar_sm" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_gravity="center" android:text="A"
                                android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold" />
                        </FrameLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Ana Santos" android:textColor="#111827"
                                android:textSize="13sp" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Mathematics" android:textColor="#0047AB"
                                android:textSize="11sp" android:textStyle="bold" android:layout_marginTop="1dp" />
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="⭐ 4.9 " android:textColor="#F59E0B"
                            android:textSize="12sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="(48)" android:textColor="#6B7280" android:textSize="12sp" />
                        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="✓" android:textColor="#0047AB"
                            android:textSize="11sp" android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Tutor card 2 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_tutor_mini_card"
                    android:padding="12dp"
                    android:layout_marginStart="6dp"
                    android:clickable="true"
                    android:focusable="true">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <FrameLayout android:layout_width="34dp" android:layout_height="34dp"
                            android:layout_marginEnd="8dp">
                            <View android:layout_width="34dp" android:layout_height="34dp"
                                android:background="@drawable/bg_avatar_sm_purple" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_gravity="center" android:text="M"
                                android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold" />
                        </FrameLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Mark Reyes" android:textColor="#111827"
                                android:textSize="13sp" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Programming" android:textColor="#0047AB"
                                android:textSize="11sp" android:textStyle="bold" android:layout_marginTop="1dp" />
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="⭐ 4.9 " android:textColor="#F59E0B"
                            android:textSize="12sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="(60)" android:textColor="#6B7280" android:textSize="12sp" />
                        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="✓" android:textColor="#0047AB"
                            android:textSize="11sp" android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

            </GridLayout>
        </LinearLayout>

        <!-- ── RECENT ACTIVITY CARD ──────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recent Activity"
                android:textColor="#111827"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <!-- Activity 1 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:paddingBottom="12dp">
                <View android:layout_width="8dp" android:layout_height="8dp"
                    android:background="@drawable/bg_dot_primary"
                    android:layout_marginTop="5dp" android:layout_marginEnd="12dp" />
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Session with Mark Reyes confirmed"
                        android:textColor="#111827" android:textSize="13sp"
                        android:lineSpacingMultiplier="1.4" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="2 hours ago" android:textColor="#6B7280"
                        android:textSize="11sp" android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#E5E8EF" android:layout_marginBottom="12dp" />

            <!-- Activity 2 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:paddingBottom="12dp">
                <View android:layout_width="8dp" android:layout_height="8dp"
                    android:background="@drawable/bg_dot_inactive"
                    android:layout_marginTop="5dp" android:layout_marginEnd="12dp" />
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="You completed a Math session"
                        android:textColor="#111827" android:textSize="13sp"
                        android:lineSpacingMultiplier="1.4" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Yesterday" android:textColor="#6B7280"
                        android:textSize="11sp" android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#E5E8EF" android:layout_marginBottom="12dp" />

            <!-- Activity 3 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <View android:layout_width="8dp" android:layout_height="8dp"
                    android:background="@drawable/bg_dot_inactive"
                    android:layout_marginTop="5dp" android:layout_marginEnd="12dp" />
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="New tutor Ana Santos joined TutorTime"
                        android:textColor="#111827" android:textSize="13sp"
                        android:lineSpacingMultiplier="1.4" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="2 days ago" android:textColor="#6B7280"
                        android:textSize="11sp" android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>